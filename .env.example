# --- SquishyGPT environment ---
# Copy to .env.local for local dev. On Railway, set these as service variables.

# Postgres connection string (Railway Postgres provides this automatically).
DATABASE_URL=postgresql://user:password@localhost:5432/squishygpt

# Set to "disable" only for a local Postgres without SSL.
# PGSSL=disable

# Anthropic (Claude) — powers the chat answers.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Optional: override the Claude model (defaults to claude-sonnet-4-5).
# ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI — used only for embeddings (RAG retrieval).
OPENAI_API_KEY=sk-xxxxxxxx
# Optional: defaults to text-embedding-3-small (1536 dims).
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Single shared password to access the site (just for Serena).
SITE_PASSWORD=change-me-to-something-only-serena-knows

# Secret used to sign the session cookie. Use a long random string.
SESSION_SECRET=generate-a-long-random-string-here
